<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Your profile</title>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link href="https://unpkg.com/boxicons@2.0.7/css/boxicons.min.css" rel="stylesheet">
  {{> ui-assets}}
  <style>
    body {
      margin: 0;
      font-family: "Segoe UI", system-ui, sans-serif;
      background: linear-gradient(165deg, #f0fdfa 0%, #f8fafc 40%, #e0f2fe 100%);
      color: #0f172a;
      min-height: 100vh;
    }
    nav {
      display: flex;
      align-items: center;
      gap: 18px;
      padding: 14px 24px;
      background: #0f766e;
      color: #fff;
    }
    nav a { color: #fff; text-decoration: none; font-weight: 600; margin-right: 12px; }
    nav h2 { margin: 0; font-size: 1.1rem; }
    main {
      max-width: 720px;
      margin: 28px auto;
      padding: 0 16px 40px;
    }
    .profile-panel {
      background: #fff;
      border-radius: 16px;
      padding: 28px;
      box-shadow: 0 14px 34px rgba(15, 23, 42, 0.08);
    }
    h1 { margin: 0 0 8px; font-size: 1.6rem; }
    .lede { color: #64748b; margin: 0 0 22px; }
    dl {
      display: grid;
      grid-template-columns: 160px 1fr;
      gap: 10px 14px;
      margin: 0;
    }
    dt { color: #64748b; font-weight: 600; }
    dd { margin: 0; font-weight: 700; }
    .actions { margin-top: 24px; display: flex; flex-wrap: wrap; gap: 10px; }
  </style>
</head>
<body>
  <nav>
    <h2>Trade Vantage</h2>
    <a href="/api/showUserStocks/stockHome">Home</a>
    <a href="/api/showUserStocks/showUserStocks">My Stocks</a>
    <a href="/api/profileauth/transactionHistory">History</a>
  </nav>
  <main>
    {{> alert}}
    {{#if user}}
    <section class="profile-panel">
      <h1>{{orDash user.name}}</h1>
      <p class="lede">Account overview for virtual trading</p>
      <dl>
        <dt>Username</dt>
        <dd>{{orDash user.username}}</dd>
        <dt>Email</dt>
        <dd>{{orDash user.email}}</dd>
        <dt>Mobile</dt>
        <dd>{{orDash user.mobNo}}</dd>
        <dt>Balance</dt>
        <dd>&#8377;{{money user.amount}}</dd>
        <dt>Profit</dt>
        <dd>&#8377;{{money user.profit}}</dd>
        <dt>Loss</dt>
        <dd>&#8377;{{money user.loss}}</dd>
      </dl>
      <div class="actions">
        <a class="ui-btn" href="/api/registerauth/changeProfile">Edit profile</a>
        <a class="ui-btn" href="/api/showUserStocks/stockSelect">Browse stocks</a>
      </div>
    </section>
    {{else}}
    {{> empty-state title="Profile unavailable" text="We could not load your account details." href="/api/loginauth/login" cta="Sign in"}}
    {{/if}}
  </main>
</body>
</html>
