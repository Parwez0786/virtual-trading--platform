<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Check your email</title>
  {{> ui-assets}}
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      font-family: "Segoe UI", system-ui, sans-serif;
      background: linear-gradient(160deg, #ecfeff 0%, #f8fafc 50%, #e0f2fe 100%);
    }
    .panel {
      width: min(460px, 92vw);
      padding: 32px 28px;
      border-radius: 16px;
      background: #fff;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
      text-align: center;
    }
    h1 { margin: 0 0 10px; font-size: 1.45rem; color: #0f766e; }
    p { margin: 0 0 20px; color: #64748b; line-height: 1.5; }
    a.ui-btn { margin: 0 6px; }
  </style>
</head>
<body>
  <div class="panel">
    {{> alert}}
    <h1>{{#if message}}{{message}}{{else}}Check your inbox{{/if}}</h1>
    <p>
      {{#if genereted_account_no}}
      Account reference: <strong>{{genereted_account_no}}</strong>
      {{else}}
      We sent the next step to your email. Open the message to continue.
      {{/if}}
    </p>
    <a class="ui-btn" href="https://mail.google.com" target="_blank" rel="noopener">Open Gmail</a>
    <a class="ui-btn" href="/api/loginauth/login">Back to login</a>
  </div>
</body>
</html>
