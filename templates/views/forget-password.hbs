<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forgot Password · Virtual Trading</title>
  {{> ui-assets}}
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      font-family: Arial, Helvetica, sans-serif;
      background: linear-gradient(160deg, #ecfdf5 0%, #f8fafc 45%, #e2e8f0 100%);
      color: #0f172a;
    }
    .wrap {
      max-width: 440px;
      margin: 48px auto;
      padding: 0 16px;
    }
    .card {
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 14px;
      padding: 28px 24px;
      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
    }
    .brand {
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #0f766e;
      font-weight: 700;
      margin: 0 0 8px;
    }
    h1 {
      margin: 0 0 8px;
      font-size: 1.6rem;
    }
    p {
      color: #64748b;
      line-height: 1.5;
    }
    label {
      display: block;
      margin: 16px 0 6px;
      font-weight: 600;
      font-size: 0.9rem;
    }
    input[type="email"] {
      width: 100%;
      box-sizing: border-box;
      padding: 12px 14px;
      border-radius: 8px;
      border: 1px solid #cbd5e1;
      font-size: 1rem;
    }
    input[type="email"]:focus {
      outline: 2px solid #99f6e4;
      border-color: #0f766e;
    }
    button {
      margin-top: 18px;
      width: 100%;
      border: 0;
      border-radius: 8px;
      padding: 12px 16px;
      background: #0f766e;
      color: #fff;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
    }
    button:hover { background: #0d9488; }
    .back {
      display: inline-block;
      margin-top: 16px;
      color: #0f766e;
      font-weight: 600;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="wrap">
    {{> alert}}
    <div class="card">
      <p class="brand">Virtual Trading</p>
      <h1>Forgot password</h1>
      <p>Enter the email on your account and we’ll send a reset link if it exists.</p>
      <form method="post" action="/api/auth/forget-password" id="forgot-password">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="you@example.com" autocomplete="email" />
        <button type="submit">Send reset link</button>
      </form>
      <a class="back" href="/api/loginauth/login">← Back to login</a>
    </div>
  </div>
</body>
</html>
